# OpenAI API Key — required. Never commit the real value.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional — defaults shown
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000
OPENAI_TIMEOUT_MS=15000

# Vercel KV — required for the submission queue.
# Vercel Blob — required for label image storage.
# Enable both in your Vercel project dashboard under Storage,
# then run: vercel env pull .env.local
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
BLOB_READ_WRITE_TOKEN=
